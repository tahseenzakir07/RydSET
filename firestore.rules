rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────

    // Check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if the requesting user is NOT blocked
    function isNotBlocked() {
      return request.auth != null &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('is_blocked', false) == false;
    }

    // ── Profiles ──────────────────────────────────────────────────────────────
    match /profiles/{userId} {
      // Any authenticated user (or public) can read profiles
      // (needed for fetching driver/passenger info in ride cards & review lookups)
      allow read: if true;

      // Users can create only their own profile
      allow create: if request.auth != null && request.auth.uid == userId;

      // Users can update their own profile (if not blocked),
      // OR authenticated users can update those fields related to ratings (prototype-mode)
      // OR admins can update ANY profile
      allow update: if (request.auth != null && request.auth.uid == userId && isNotBlocked())
                    || (request.auth != null && isNotBlocked() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['average_rating', 'rating_count', 'flagged', 'flagged_reason']))
                    || isAdmin();

      // Only admins can delete profiles
      allow delete: if isAdmin();
    }

    // ── Rides ─────────────────────────────────────────────────────────────────
    match /rides/{rideId} {
      // Anyone can read rides (needed for Dashboard discovery)
      allow read: if true;

      // Only non-blocked, authenticated users can create rides (as driver)
      allow create: if isNotBlocked() &&
                       request.auth.uid == request.resource.data.driver_id;

      // Drivers can update/delete their own rides; admins can update any
      allow update, delete: if (isNotBlocked() && request.auth.uid == resource.data.driver_id)
                            || isAdmin();
    }

    // ── Bookings ──────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Passengers and drivers involved in a booking can read it; admins can read all
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.passenger_id ||
        request.auth.uid == resource.data.driver_id ||
        isAdmin()
      );

      // Non-blocked passengers can create bookings
      allow create: if isNotBlocked() &&
                       request.auth.uid == request.resource.data.passenger_id;

      // Passengers OR drivers can update bookings (OTP, status changes, etc.),
      // as long as they are not blocked; admins can always update
      allow update: if (isNotBlocked() && (
                          request.auth.uid == resource.data.passenger_id ||
                          request.auth.uid == resource.data.driver_id
                        ))
                    || isAdmin();

      // Passengers can delete their own bookings; admins can delete any
      allow delete: if (isNotBlocked() && request.auth.uid == resource.data.passenger_id)
                    || isAdmin();
    }

    // ── Ratings ───────────────────────────────────────────────────────────────
    match /ratings/{ratingId} {
      // Any authenticated user can read ratings
      // (needed for the "My Reviews" section on profiles and for ride cards)
      allow read: if request.auth != null;

      // Non-blocked authenticated users can create ratings (as the rater)
      allow create: if isNotBlocked() &&
                       request.auth.uid == request.resource.data.rater_id;

      // Only admins can update or delete ratings
      allow update, delete: if isAdmin();
    }

    // ── Chat Messages ─────────────────────────────────────────────────────────
    match /chats/{chatId}/messages/{messageId} {
      // Participants of the chat can read messages
      allow read: if request.auth != null;

      // Non-blocked users can send messages
      allow create: if isNotBlocked();

      allow update, delete: if isAdmin();
    }

    // ── Default Deny ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
